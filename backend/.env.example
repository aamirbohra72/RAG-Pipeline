MISTRAL_API_KEY=your_mistral_api_key_here

# Auth
JWT_SECRET=dev-only-change-me-use-a-long-random-secret

# Vector store: pgvector (Neon cloud) or chroma (local ./chroma_db)
VECTOR_BACKEND=pgvector
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# LangSmith monitoring — https://smith.langchain.com → API Keys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=genai-rag

# Async PDF ingest via Celery + Upstash Redis (rediss:// = TLS)
ASYNC_INGEST=true
REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR-DB.upstash.io:6379/0

# Optional overrides
# TOP_K=4
# CANDIDATE_POOL=20
# RERANK_ENABLED=true
# OCR_ENABLED=true
# CORS_ORIGINS=http://localhost:3000
